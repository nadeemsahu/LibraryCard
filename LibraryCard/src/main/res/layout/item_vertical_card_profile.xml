<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/glass_card_background"
    android:layout_marginBottom="12dp"
    android:padding="18dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nadeem's Primary Card"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"/>

        <TextView
            android:id="@+id/tvProfileId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ID: HUHS05856860"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <Button
        android:id="@+id/btnSetAsActive"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="Activate"
        android:textColor="@color/bg_surface"
        android:textSize="11sp"
        android:backgroundTint="@color/accent_lime"
        android:layout_marginLeft="8dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:textAllCaps="false"/>

    <ImageButton
        android:id="@+id/btnDeleteCard"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_close"
        app:tint="@color/text_secondary"
        android:background="@drawable/scan_button_background"
        android:backgroundTint="@color/bg_card"
        android:layout_marginLeft="8dp"
        android:padding="8dp"
        android:scaleType="fitCenter"/>

</LinearLayout>
