<resources>
    <!-- ═══ PREMIUM VAULT — App Theme ═══ -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/bg_void</item>
        <item name="colorPrimaryDark">@color/bg_void</item>
        <item name="colorAccent">@color/accent_lime</item>
        <item name="android:windowBackground">@color/bg_void</item>
        <item name="android:statusBarColor">@color/bg_void</item>
        <item name="android:navigationBarColor">@color/bg_void</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- Fullscreen card experience theme -->
    <style name="CardFullscreenTheme" parent="AppTheme">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <!-- ═══ LUXURY BRAND — Styled Alert Dialogs ═══ -->
    <style name="CustomDialogTheme" parent="Theme.AppCompat.DayNight.Dialog.Alert">
        <item name="android:background">#121319</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:textColorPrimary">#E5E5E5</item>
        <item name="android:textColorSecondary">#8A8A9E</item>
        <item name="colorAccent">#D9FF3F</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogPositiveButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogNegativeButton</item>
    </style>

    <style name="DialogPositiveButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#D9FF3F</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="DialogNegativeButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">#8A8A9E</item>
    </style>
</resources>
